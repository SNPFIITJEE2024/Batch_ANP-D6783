#a teacher is reading the attendance. the strength is 30. everytime he needs to insert student is present or absent. calculate the total no. of present & absent student
#setting & initializing counter to 0
present_count = 0
absent_count = 0
total_students = 0
#iterating over class strength ( total no. of students )
for i in range(1,total_students + 1)

status = input(f"Is Student #{i} Present (P) or Absent (A)? ").upper())
if status = "P":
    present_count += 1
elif status = "ab":
    absent_count += 1
else: 
    print ("invalid statement! please enter either 'P' or 'A'.")

print("\n--- Attendance Summary ---")
print(f"Total Students Present: {present_count}")
print(f"Total Students Absent: {absent_count}")